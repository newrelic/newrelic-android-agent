<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Session Replay Performance Test"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="XML-Based Layouts"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnInfiniteScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Infinite Scroll"
            android:contentDescription="Infinite Scroll"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnImageGallery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Image Gallery"
            android:contentDescription="Image Gallery"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUIElements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="UI Elements"
            android:contentDescription="UI Elements"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNetworkTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Network Test"
            android:contentDescription="Network Test"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNavigationFlow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Navigation Flow"
            android:contentDescription="Navigation Flow"
            android:layout_marginBottom="24dp" />

        <!-- Hidden TextView for metrics (visible but tiny for Appium) -->
        <TextView
            android:id="@+id/metricsTextView"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:textSize="1sp"
            android:alpha="0.01"
            android:contentDescription="performance_metrics_json"
            android:text="[]" />

    </LinearLayout>

</ScrollView>
